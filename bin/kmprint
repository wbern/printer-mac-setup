#!/usr/bin/env python3
"""
Print a file to the Olivetti MF224 / Konica Minolta bizhub C250i at
192.168.9.15 by prepending the PJL user-authentication header it requires.

Usage:
    PRINTER_USER=abc PRINTER_PASS=1234 kmprint <file>
    kmprint --user abc --pass 1234 <file>

Credentials must come from env vars PRINTER_USER / PRINTER_PASS or the
matching CLI flags — there are no defaults, so this script can't accidentally
attribute someone else's print to the wrong user.

The script:
  1. Converts the input file (PDF/PS/image/text) to PostScript via the system
     `cupsfilter` pipeline against the Olivetti_MF224 PPD, so MediaType, page
     size, and KM Output Method options the queue is configured with are
     honored.
  2. Wraps the PostScript in a @PJL JOB ... @PJL EOJ envelope with the auth
     SET lines the bizhub needs (PRIVATE box-hold, KMUSERNAME, KMUSERKEY2,
     KMCERTSERVTYPE = NUMBER, KMCERTSERVNUM = 101).
  3. Sends the bytes to the printer on TCP/9100.

Verify the result with `verify/verify_jobs.py --since HH:MM` — a successful
print shows up as status OK with a non-zero page count.
"""
import argparse
import os
import socket
import subprocess
import sys

DEFAULT_HOST = "192.168.9.15"
DEFAULT_PORT = 9100
DEFAULT_QUEUE = "Olivetti_MF224"


def pjl_envelope(user: str, password: str, ps_bytes: bytes) -> bytes:
    head = (
        b"\x1b%-12345X@PJL JOB\n"
        b"@PJL SET BOXHOLDTYPE = PRIVATE\n"
        b'@PJL SET KMUSERNAME = "' + user.encode() + b'" \n'
        b'@PJL SET KMUSERKEY2 = "' + password.encode() + b'" \n'
        b"@PJL SET KMCERTSERVTYPE = NUMBER\n"
        b"@PJL SET KMCERTSERVNUM = 101\n"
        b"@PJL ENTER LANGUAGE = POSTSCRIPT\n"
    )
    tail = b"\n\x1b%-12345X@PJL EOJ\n\x1b%-12345X"
    return head + ps_bytes + tail


def to_postscript(path: str, queue: str) -> bytes:
    # cupsfilter renders any supported input format to the final PDL for the
    # named queue. -m forces PostScript output so we can wrap it in PJL.
    out = subprocess.run(
        ["cupsfilter", "-p", f"/etc/cups/ppd/{queue}.ppd",
         "-m", "application/postscript", path],
        capture_output=True, check=False,
    )
    if out.returncode != 0:
        sys.stderr.write(out.stderr.decode(errors="replace"))
        raise SystemExit(f"cupsfilter failed (exit {out.returncode})")
    return out.stdout


def send(host: str, port: int, payload: bytes) -> None:
    with socket.create_connection((host, port), timeout=30) as s:
        s.sendall(payload)
        s.shutdown(socket.SHUT_WR)


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("file", help="file to print (PDF, PS, image, text…)")
    ap.add_argument("--user", default=os.environ.get("PRINTER_USER"))
    ap.add_argument("--password", "--pass", dest="password",
                    default=os.environ.get("PRINTER_PASS"))
    ap.add_argument("--host", default=DEFAULT_HOST)
    ap.add_argument("--port", type=int, default=DEFAULT_PORT)
    ap.add_argument("--queue", default=DEFAULT_QUEUE,
                    help="CUPS queue whose PPD to use for rasterization")
    args = ap.parse_args()

    if not args.user or not args.password:
        raise SystemExit(
            "missing credentials — set PRINTER_USER and PRINTER_PASS env vars "
            "or pass --user and --password"
        )

    if not os.path.exists(args.file):
        raise SystemExit(f"no such file: {args.file}")

    ps = to_postscript(args.file, args.queue)
    payload = pjl_envelope(args.user, args.password, ps)
    send(args.host, args.port, payload)
    sys.stderr.write(
        f"sent {len(payload)} bytes to {args.host}:{args.port} "
        f"(user={args.user!r}, ps_size={len(ps)})\n"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
